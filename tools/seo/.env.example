# Copy this file to tools/seo/.env and fill local values.
# Never commit or share the real .env file.

WINCHER_API_TOKEN=

# Optional default website ID used by scripts.
# If unknown, run:
#   cd tools/seo/wincher
#   python3 wincher_connector.py --mode websites
WINCHER_WEBSITE_ID=

# Optional notes for the target website workspace.
WEBSITE_DOMAIN=https://voiceoveraihub.com
GITHUB_REPOSITORY=affiliate-stack/voiceover-ai-hub

# Google Search Console
# Use the exact property string from Search Console:
# - URL-prefix property example: https://example.com/
# - Domain property example: sc-domain:example.com
GSC_SITE_URL=https://voiceoveraihub.com/

# OAuth desktop/client credentials downloaded from Google Cloud Console.
# Store the JSON file locally in tools/seo/google/ or use an absolute path.
GOOGLE_CLIENT_SECRETS_FILE=client_secret.json
GOOGLE_TOKEN_FILE=token.json

# Optional one-off OAuth access token. It expires and cannot refresh by itself.
GOOGLE_ACCESS_TOKEN=

# Optional alternative for automation. The service account must be added to Search Console.
GOOGLE_SERVICE_ACCOUNT_FILE=

# PageSpeed Insights
# Optional for light usage, recommended for repeated automated runs.
PAGESPEED_API_KEY=

# Comma-separated public URLs to test.
PAGESPEED_URLS=https://voiceoveraihub.com/,https://voiceoveraihub.com/ko/,https://voiceoveraihub.com/tools/script_length/script_length.html,https://voiceoveraihub.com/ko/tools/script_length/script_length.html,https://voiceoveraihub.com/privacy.html
