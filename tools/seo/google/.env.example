# Copy this file to tools/seo/google/.env only if you do not use shared tools/seo/.env.
# Never commit or share the real .env, OAuth token file, API keys, or credential JSON files.

# Search Console property. Use the exact property string from Search Console:
# - URL-prefix property example: https://example.com/
# - Domain property example: sc-domain:example.com
GSC_SITE_URL=https://voiceoveraihub.com/

# OAuth desktop/client secrets JSON downloaded from Google Cloud Console.
# Keep this file inside tools/seo/google/ or provide an absolute path.
GOOGLE_CLIENT_SECRETS_FILE=client_secret.json
GOOGLE_TOKEN_FILE=token.json

# Optional one-off OAuth access token. This expires and cannot be refreshed without OAuth client credentials.
# Do not use an API key here; Search Console requires OAuth or service account authorization.
GOOGLE_ACCESS_TOKEN=

# Optional alternative for automation. The service account must be added to Search Console.
GOOGLE_SERVICE_ACCOUNT_FILE=

# Optional PageSpeed Insights key. PageSpeed can run without this for light usage.
PAGESPEED_API_KEY=

# Comma-separated URLs for PageSpeed exports.
PAGESPEED_URLS=https://voiceoveraihub.com/,https://voiceoveraihub.com/ko/,https://voiceoveraihub.com/tools/script_length/script_length.html,https://voiceoveraihub.com/ko/tools/script_length/script_length.html,https://voiceoveraihub.com/privacy.html
